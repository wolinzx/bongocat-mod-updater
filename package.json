{
  "name": "cat-update-updater-electron",
  "version": "1.0.0",
  "description": "Electron updater for a fixed Lanzou RAR package.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "fs-extra": "^11.3.2",
    "node-unrar-js": "^2.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  },
  "build": {
    "appId": "com.claude.catupdater",
    "productName": "Cat Updater",
    "asarUnpack": [
      "node_modules/7zip-bin/**"
    ],
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
